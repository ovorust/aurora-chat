name: Deploy Aurora to GitHub Pages

on:
  push:
    branches: [main]      # dispara em todo push na main
  workflow_dispatch:       # ou manualmente pelo painel do GitHub

permissions:
  contents: read
  pages:    write
  id-token: write

concurrency:
  group: pages
  cancel-in-progress: true

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest

    steps:
      # 1. Baixa o repositório
      - name: Checkout
        uses: actions/checkout@v4

      # 2. Gera aurora-cfg.js usando a key armazenada no secret do GitHub
      #    O arquivo é criado em runtime — nunca está no repo
      - name: Gerar aurora-cfg.js
        env:
          OPENROUTER_KEY: ${{ secrets.OPENROUTER_KEY }}
        run: |
          node -e "
          const key  = process.env.OPENROUTER_KEY;
          const salt = 'zoe_juridica_2024';

          if (!key) { console.error('OPENROUTER_KEY secret não definido!'); process.exit(1); }

          function xor(str, s) {
            return Array.from(str)
              .map((c, i) => String.fromCharCode(c.charCodeAt(0) ^ s.charCodeAt(i % s.length)))
              .join('');
          }

          const encoded = Buffer.from(xor(key, salt), 'binary').toString('base64');
          const q  = Math.floor(encoded.length / 4);
          const p  = [encoded.slice(0,q), encoded.slice(q,q*2), encoded.slice(q*2,q*3), encoded.slice(q*3)];

          // Armazena embaralhado: ordem [2,0,3,1], restaura com [1,3,0,2]
          const shuffled = [p[2], p[0], p[3], p[1]];

          const output = \`/* aurora-cfg.js — gerado automaticamente, não editar */
          (function () {
            'use strict';
            var _p = \${JSON.stringify(shuffled)};
            var _o = [1, 3, 0, 2];
            var _s = 'zoe_juridica_2024';
            function _xor(str, key) {
              var out = '';
              for (var i = 0; i < str.length; i++)
                out += String.fromCharCode(str.charCodeAt(i) ^ key.charCodeAt(i % key.length));
              return out;
            }
            var _r = null;
            Object.defineProperty(window, '__cfg', {
              get: function () {
                if (!_r) _r = _xor(atob(_o.map(function(i){ return _p[i]; }).join('')), _s);
                return { ak: _r };
              },
              configurable: false,
              enumerable:   false
            });
          })();
          \`;

          require('fs').writeFileSync('aurora-cfg.js', output.replace(/^          /gm, ''));
          console.log('aurora-cfg.js gerado com sucesso.');
          "

      # 3. Empacota os arquivos que vão para o GitHub Pages
      - name: Preparar artefato
        uses: actions/upload-pages-artifact@v3
        with:
          path: .        # sobe tudo da raiz (inclui o aurora-cfg.js recém-criado)

      # 4. Faz o deploy no GitHub Pages
      - name: Deploy
        uses: actions/deploy-pages@v4
